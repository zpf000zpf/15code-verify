# Public URL for API (used by web to call)
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS allowed origins for API (comma-separated, * = any)
CORS_ORIGINS=*

# Optional: official keys used by Ground Truth baseline job
# (ONLY 15code's own keys — never user-provided keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
